{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit user experience capability matrix fixture",
  "type": "object",
  "required": ["reportType", "schemaVersion", "matrixId", "capabilities"],
  "properties": {
    "reportType": { "const": "ux-capability-matrix" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "matrixId": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "enum": ["machine", "default-user", "current-user", "offline-image"]
    },
    "feature": {
      "type": "string",
      "enum": ["default-apps", "start-menu", "taskbar", "app-visibility", "verification"]
    },
    "supportStatus": {
      "type": "string",
      "enum": ["planned-supported", "report-only", "manual-or-future", "unsupported", "blocked"]
    },
    "verificationMode": {
      "type": "string",
      "enum": ["fixture", "report-only", "manual-checklist", "future-real-verification"]
    },
    "capability": {
      "type": "object",
      "required": ["id", "displayVersion", "buildMin", "buildMax", "scope", "feature", "supportStatus", "verificationMode", "mutationAllowed"],
      "properties": {
        "id": { "type": "string" },
        "displayVersion": { "type": "string" },
        "buildMin": { "type": "integer", "minimum": 1 },
        "buildMax": { "type": "integer", "minimum": 1 },
        "scope": { "$ref": "#/$defs/scope" },
        "feature": { "$ref": "#/$defs/feature" },
        "supportStatus": { "$ref": "#/$defs/supportStatus" },
        "verificationMode": { "$ref": "#/$defs/verificationMode" },
        "mutationAllowed": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
