{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit Defender exclusion manifest",
  "type": "object",
  "required": ["exclusions"],
  "properties": {
    "$schema": { "type": "string" },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "value", "scope", "reason", "required", "failurePolicy"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?!\\s*$)[A-Za-z0-9][A-Za-z0-9_.-]*$"
          },
          "type": {
            "type": "string",
            "enum": ["path", "process"]
          },
          "value": {
            "type": "string",
            "pattern": "^(?!\\s*$).+"
          },
          "scope": {
            "type": "string",
            "pattern": "^(?!\\s*$).+"
          },
          "reason": {
            "type": "string",
            "pattern": "^(?!\\s*$).+"
          },
          "required": {
            "type": "boolean"
          },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          },
          "enabled": {
            "type": "boolean"
          },
          "owner": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "stateChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["settingName", "expectedValue"],
        "properties": {
          "name": { "type": "string" },
          "settingName": { "type": "string", "pattern": "^(?!\\s*$).+" },
          "expectedValue": {},
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
