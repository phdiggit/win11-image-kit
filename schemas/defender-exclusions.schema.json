{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit Defender 排除项清单",
  "type": "object",
  "required": ["paths", "processes"],
  "properties": {
    "$schema": { "type": "string" },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "path"],
        "properties": {
          "description": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "processes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "path"],
        "properties": {
          "description": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "stateChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["settingName", "expectedValue"],
        "properties": {
          "name": { "type": "string" },
          "settingName": { "type": "string" },
          "expectedValue": {},
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
