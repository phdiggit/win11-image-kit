{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit customization scope",
  "type": "object",
  "required": ["profile", "goal", "pathsManifest", "system", "appx", "applications", "userInteraction"],
  "properties": {
    "$schema": { "type": "string" },
    "profile": { "type": "string" },
    "goal": { "type": "string" },
    "pathsManifest": { "type": "string" },
    "configLayersManifest": { "type": "string" },
    "defaultStack": { "type": "string" },
    "system": {
      "type": "object",
      "required": ["contextMenu", "startMenu", "explorerOptions", "defaultApps", "windowsDefender", "huorong"],
      "properties": {
        "contextMenu": { "$ref": "#/$defs/enabledBlock" },
        "startMenu": { "$ref": "#/$defs/enabledBlock" },
        "windowsTerminal": { "$ref": "#/$defs/enabledBlock" },
        "explorerOptions": { "$ref": "#/$defs/enabledBlock" },
        "defaultApps": { "$ref": "#/$defs/enabledBlock" },
        "vscodePortable": { "$ref": "#/$defs/enabledBlock" },
        "windowsDefender": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["enabled", "enabled-with-exclusions", "disabled"]
            },
            "exclusionsManifest": { "type": "string" }
          },
          "additionalProperties": true
        },
        "huorong": {
          "type": "object",
          "required": ["install"],
          "properties": {
            "install": { "type": "boolean" },
            "packageName": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "appx": {
      "type": "object",
      "required": ["policy", "removeManifest", "keepPatterns"],
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["audit-only", "remove-listed-microsoft-apps"]
        },
        "removeManifest": { "type": "string" },
        "keepPatterns": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "applications": {
      "type": "object",
      "required": ["softwareManifest", "servicesManifest", "junctionsManifest"],
      "properties": {
        "softwareManifest": { "type": "string" },
        "servicesManifest": { "type": "string" },
        "junctionsManifest": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reporting": {
      "type": "object",
      "properties": {
        "build": { "$ref": "#/$defs/reportingBlock" },
        "postDeploy": { "$ref": "#/$defs/reportingBlock" },
        "validation": { "$ref": "#/$defs/reportingBlock" }
      },
      "additionalProperties": false
    },
    "userExperienceRestore": {
      "type": "object",
      "required": [
        "defaultMode",
        "scopes",
        "defaultUserIsCurrentUser",
        "offlineImageIsCurrentMachine",
        "allowRegistryMutation",
        "allowProfileMutation",
        "allowDefaultAppMutation",
        "allowStartMenuMutation",
        "allowTaskbarMutation"
      ],
      "properties": {
        "defaultMode": {
          "type": "string",
          "enum": ["plan-only", "report-only", "fixture"]
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["default-user", "current-user", "offline-image", "machine"]
          },
          "uniqueItems": true
        },
        "defaultUserIsCurrentUser": { "const": false },
        "offlineImageIsCurrentMachine": { "const": false },
        "allowRegistryMutation": { "const": false },
        "allowProfileMutation": { "const": false },
        "allowDefaultAppMutation": { "const": false },
        "allowStartMenuMutation": { "const": false },
        "allowTaskbarMutation": { "const": false }
      },
      "additionalProperties": false
    },
    "userInteraction": {
      "type": "object",
      "required": ["editableBeforeRun", "allowedChanges"],
      "properties": {
        "editableBeforeRun": { "type": "boolean" },
        "allowedChanges": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "enabledBlock": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "stateChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/configStateCheck" }
        }
      },
      "additionalProperties": true
    },
    "configStateCheck": {
      "type": "object",
      "required": ["name", "domain", "settingName", "expectedValue"],
      "properties": {
        "name": { "type": "string" },
        "domain": {
          "type": "string",
          "enum": ["explorer", "startMenu", "terminal", "defaultApps", "contextMenu", "userExperience"]
        },
        "settingName": { "type": "string" },
        "expectedValue": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "string" },
            { "type": "integer" },
            { "type": "number" }
          ]
        },
        "required": { "type": "boolean" },
        "failurePolicy": {
          "type": "string",
          "enum": ["fail", "skip", "manual"]
        }
      },
      "additionalProperties": false
    },
    "reportingBlock": {
      "type": "object",
      "required": ["enabled", "logDirectory", "reportDirectory"],
      "properties": {
        "enabled": { "type": "boolean" },
        "logDirectory": { "type": "string" },
        "reportDirectory": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
