{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit software manifest",
  "type": "object",
  "required": ["packages"],
  "properties": {
    "$schema": { "type": "string" },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "stage", "type"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "enabled": { "type": "boolean" },
          "category": { "type": "string" },
          "stage": {
            "type": "string",
            "enum": ["golden-image", "post-deploy", "manual"]
          },
          "type": {
            "type": "string",
            "enum": ["archive", "zip", "installer", "manual"]
          },
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          },
          "allowMissingSource": { "type": "boolean" },
          "archiveFormat": {
            "type": "string",
            "enum": ["zip", "tar.gz"]
          },
          "source": { "type": "string" },
          "sha256": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              },
              { "type": "null" }
            ]
          },
          "destination": { "type": "string" },
          "installArgs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "silentInstall": { "type": "boolean" },
          "successExitCodes": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "testCommand": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": { "type": "string" },
              "arguments": {
                "type": "array",
                "items": { "type": "string" }
              },
              "successExitCodes": {
                "type": "array",
                "items": { "type": "integer" }
              },
              "timeoutSeconds": {
                "type": "integer",
                "minimum": 1
              },
              "failurePolicy": {
                "type": "string",
                "enum": ["fail", "skip", "manual"]
              }
            },
            "additionalProperties": false
          },
          "uninstall": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "path": {
            "type": "array",
            "items": { "type": "string" }
          },
          "postInstall": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": ["ensure-directory"]
                },
                "path": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "test": { "type": "string" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "type": { "const": "archive" } },
              "required": ["type"]
            },
            "then": {
              "required": ["source", "destination", "archiveFormat"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "zip" } },
              "required": ["type"]
            },
            "then": {
              "required": ["source", "destination"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "installer" } },
              "required": ["type"]
            },
            "then": {
              "required": ["source", "destination", "silentInstall"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
