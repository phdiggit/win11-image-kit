{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit ensure-state software manifest",
  "type": "object",
  "required": [
    "manifestVersion",
    "software"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "integer",
      "minimum": 1
    },
    "software": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "displayName",
          "ensure",
          "source",
          "packageId",
          "scope",
          "installMode",
          "priority",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "ensure": {
            "type": "string",
            "enum": [
              "present",
              "absent",
              "latest",
              "pinned",
              "manual"
            ]
          },
          "source": {
            "type": "string",
            "enum": [
              "winget",
              "chocolatey",
              "msi",
              "powershell",
              "manual",
              "none"
            ]
          },
          "packageId": {
            "type": "string"
          },
          "version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "machine",
              "current-user",
              "default-user",
              "none"
            ]
          },
          "installMode": {
            "type": "string",
            "enum": [
              "planned",
              "manual",
              "disabled"
            ]
          },
          "priority": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
