{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit AppX cleanup policy",
  "type": "object",
  "required": ["policy", "removeNamePatterns", "keepNamePatterns"],
  "properties": {
    "$schema": { "type": "string" },
    "policy": {
      "type": "string",
      "enum": ["audit-only", "remove-listed-microsoft-apps"]
    },
    "removeNamePatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keepNamePatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stateChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["packageName", "scope", "expectedState"],
        "properties": {
          "name": { "type": "string" },
          "packageName": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["provisioned", "user", "allUsers"]
          },
          "expectedState": {
            "type": "string",
            "enum": ["present", "absent"]
          },
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
