{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit controlled execution manifest",
  "type": "object",
  "required": ["manifestVersion", "executionSetId", "defaultMode", "allowTrueExecution", "actions", "safety"],
  "properties": {
    "$schema": { "type": "string" },
    "manifestVersion": {
      "type": "integer",
      "minimum": 1
    },
    "executionSetId": {
      "type": "string",
      "minLength": 1
    },
    "defaultMode": {
      "$ref": "#/$defs/executionMode"
    },
    "allowTrueExecution": {
      "type": "boolean",
      "const": false,
      "default": false
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "safety": { "$ref": "#/$defs/safety" }
  },
  "$defs": {
    "executionMode": {
      "type": "string",
      "enum": ["dry-run", "what-if", "plan-only", "manual"]
    },
    "actionMode": {
      "type": "string",
      "enum": ["report-only", "fixture", "manual", "plan-only"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "mutationKind": {
      "type": "string",
      "enum": ["none", "planned-only", "disk", "registry", "network-download", "service", "profile", "hive", "winpe", "system-state"]
    },
    "action": {
      "type": "object",
      "required": ["id", "stage", "mode", "entrypoint", "requiresAdmin", "requiresWinPE", "requiresNetwork", "requiresReboot", "mutationKind", "riskLevel", "evidenceProducer"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "stage": { "type": "string", "minLength": 1 },
        "mode": { "$ref": "#/$defs/actionMode" },
        "entrypoint": { "type": "string", "minLength": 1 },
        "requiresAdmin": { "type": "boolean" },
        "requiresWinPE": { "type": "boolean" },
        "requiresNetwork": { "type": "boolean" },
        "requiresReboot": { "type": "boolean" },
        "mutationKind": { "$ref": "#/$defs/mutationKind" },
        "riskLevel": { "$ref": "#/$defs/riskLevel" },
        "evidenceProducer": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "executionPolicy": {
          "type": "string",
          "enum": ["plan-only", "simulation", "report-only", "manual"]
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": ["trueExecutionDefault", "allowDiskMutation", "allowRegistryMutation", "allowNetworkDownload", "allowServiceMutation", "allowProfileMutation", "allowHiveMutation"],
      "properties": {
        "trueExecutionDefault": { "type": "boolean", "const": false, "default": false },
        "allowDiskMutation": { "type": "boolean", "const": false, "default": false },
        "allowRegistryMutation": { "type": "boolean", "const": false, "default": false },
        "allowNetworkDownload": { "type": "boolean", "const": false, "default": false },
        "allowServiceMutation": { "type": "boolean", "const": false, "default": false },
        "allowProfileMutation": { "type": "boolean", "const": false, "default": false },
        "allowHiveMutation": { "type": "boolean", "const": false, "default": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
