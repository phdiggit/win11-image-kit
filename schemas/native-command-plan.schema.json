{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit native command plan fixture",
  "type": "object",
  "required": ["reportType", "schemaVersion", "commands", "status"],
  "properties": {
    "reportType": { "type": "string", "const": "native-command-plan" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" }
    },
    "status": { "type": "string", "enum": ["planned", "blocked"] }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": ["commandName", "plannedCommand", "expectedExitCodes", "actualExitCode", "stdout", "stderr", "status"],
      "properties": {
        "commandName": { "type": "string", "minLength": 1 },
        "plannedCommand": { "type": "string", "minLength": 1 },
        "expectedExitCodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0 }
        },
        "actualExitCode": { "type": "string", "const": "not-run" },
        "stdout": { "type": "string", "const": "not-captured" },
        "stderr": { "type": "string", "const": "not-captured" },
        "status": { "type": "string", "enum": ["planned", "blocked"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
