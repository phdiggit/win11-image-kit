{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit ensure-state service manifest",
  "type": "object",
  "required": [
    "manifestVersion",
    "services"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "integer",
      "minimum": 1
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "displayName",
          "ensure",
          "startupType",
          "scope",
          "changeMode",
          "priority",
          "reason",
          "notes"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "ensure": {
            "type": "string",
            "enum": [
              "running",
              "stopped",
              "disabled",
              "manual",
              "absent",
              "ignore"
            ]
          },
          "startupType": {
            "type": "string",
            "enum": [
              "automatic",
              "manual",
              "disabled",
              "unchanged"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "machine",
              "none"
            ]
          },
          "changeMode": {
            "type": "string",
            "enum": [
              "planned",
              "manual",
              "disabled"
            ]
          },
          "priority": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
