{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit service manifest",
  "type": "object",
  "required": ["services"],
  "properties": {
    "$schema": { "type": "string" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "displayName", "install", "start", "stop", "delete"],
        "properties": {
          "name": { "type": "string" },
          "displayName": { "type": "string" },
          "install": { "type": "string" },
          "start": { "type": "string" },
          "stop": { "type": "string" },
          "delete": { "type": "string" },
          "expectedState": {
            "type": "string",
            "enum": ["Running", "Stopped", "Paused"]
          },
          "expectedStartType": {
            "type": "string",
            "enum": ["Automatic", "Manual", "Disabled"]
          },
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
