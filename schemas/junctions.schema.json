{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "win11-image-kit junction manifest",
  "type": "object",
  "required": ["junctions"],
  "properties": {
    "$schema": { "type": "string" },
    "junctions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "source", "target"],
        "properties": {
          "description": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "required": { "type": "boolean" },
          "failurePolicy": {
            "type": "string",
            "enum": ["fail", "skip", "manual"]
          },
          "onTargetConflict": {
            "type": "string",
            "enum": ["fail"],
            "default": "fail"
          },
          "backupRetention": {
            "type": "string",
            "enum": ["keep", "delete"],
            "default": "keep"
          },
          "verificationMode": {
            "type": "string",
            "enum": ["countAndSize"],
            "default": "countAndSize"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
