{
  "$schema": "../schemas/config-layers.schema.json",
  "manifestVersion": 1,
  "mergePolicy": {
    "object": "deep-merge",
    "array": "replace",
    "scalar": "replace",
    "null": "remove"
  },
  "layers": [
    {
      "id": "repo-default",
      "kind": "repo-default",
      "required": true,
      "tracked": true,
      "path": "manifests/paths.json",
      "schema": "schemas/paths.schema.json",
      "description": "仓库默认路径意图，保持当前单文件入口兼容。"
    },
    {
      "id": "profile-default",
      "kind": "profile",
      "required": true,
      "tracked": true,
      "path": "profiles/default.json",
      "schema": "schemas/config-layer-fragment.schema.json",
      "description": "默认 profile 覆盖层，首批只声明空覆盖。"
    },
    {
      "id": "profile-release",
      "kind": "profile",
      "required": true,
      "tracked": true,
      "path": "profiles/release.json",
      "schema": "schemas/config-layer-fragment.schema.json",
      "description": "Release profile 覆盖层，用于后续锁定构建输出路径。"
    },
    {
      "id": "hardware-air15",
      "kind": "hardware",
      "required": true,
      "tracked": true,
      "path": "hardware/air15.json",
      "schema": "schemas/config-layer-fragment.schema.json",
      "description": "Air15 硬件差异覆盖示例，当前只覆盖报告工作目录。"
    },
    {
      "id": "local-private",
      "kind": "local",
      "required": false,
      "tracked": false,
      "path": "manifests/paths.local.json",
      "schema": "schemas/config-layer-fragment.schema.json",
      "description": "本机私有路径覆盖，必须保持未跟踪。"
    }
  ],
  "stacks": [
    {
      "name": "default",
      "layers": [
        "repo-default",
        "profile-default"
      ],
      "description": "默认配置层级，兼容现有 paths.json。"
    },
    {
      "name": "release",
      "layers": [
        "repo-default",
        "profile-release"
      ],
      "description": "Release 构建配置层级，首批只输出有效配置报告。"
    },
    {
      "name": "air15",
      "layers": [
        "repo-default",
        "profile-default",
        "hardware-air15"
      ],
      "description": "示例硬件层级，用于验证硬件覆盖优先级。"
    }
  ],
  "localOverrideLayer": "local-private",
  "safety": {
    "allowedPathTokens": [
      "NasProjectRoot",
      "ConfigRoot",
      "PackageRoot",
      "ImageRoot",
      "DeployRoot",
      "WorkRoot",
      "DownloadPool",
      "ToolRoot",
      "DataRoot"
    ],
    "forbiddenPathPatterns": [
      "\\\\\\\\192\\.168\\.1\\.37\\\\images",
      "\\\\\\\\192\\.168\\.1\\.37\\\\backups\\\\packages"
    ],
    "forbidTrackedLocalOverrides": true
  }
}
