{
  "$schema": "../schemas/services.schema.json",
  "services": [
    {
      "name": "MySQL",
      "displayName": "MySQL",
      "install": "\"${ToolRoot}\\mysql\\bin\\mysqld.exe\" --install MySQL --defaults-file=\"${ToolRoot}\\mysql\\my.ini\"",
      "start": "net start MySQL",
      "stop": "net stop MySQL",
      "delete": "sc delete MySQL"
    },
    {
      "name": "MongoDB",
      "displayName": "MongoDB",
      "install": "\"${ToolRoot}\\mongodb\\bin\\mongod.exe\" --config \"${ToolRoot}\\mongodb\\mongod.cfg\" --install",
      "start": "net start MongoDB",
      "stop": "net stop MongoDB",
      "delete": "sc delete MongoDB"
    }
  ]
}
