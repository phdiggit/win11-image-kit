{
  "$schema": "../schemas/services.schema.json",
  "services": [
    {
      "name": "MySQL",
      "displayName": "MySQL",
      "install": "C:\\tools\\mysql\\bin\\mysqld --install MySQL --defaults-file=C:/tools/mysql/my.ini",
      "start": "net start MySQL",
      "stop": "net stop MySQL",
      "delete": "sc delete MySQL"
    },
    {
      "name": "MongoDB",
      "displayName": "MongoDB",
      "install": "C:\\tools\\mongodb\\bin\\mongod.exe --config C:\\tools\\mongodb\\mongod.cfg --install",
      "start": "net start MongoDB",
      "stop": "net stop MongoDB",
      "delete": "sc delete MongoDB"
    }
  ]
}
