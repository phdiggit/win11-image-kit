{
  "$schema": "../schemas/defender-exclusions.schema.json",
  "exclusions": [
    {
      "id": "kit-work-cache",
      "type": "path",
      "value": "${WorkRoot}\\cache",
      "scope": "kit-work-cache",
      "reason": "Avoid repeated scanning of kit-managed temporary build cache files.",
      "required": false,
      "failurePolicy": "manual"
    },
    {
      "id": "kit-deploy-reports",
      "type": "path",
      "value": "${DeployRoot}\\reports",
      "scope": "kit-deploy-reports",
      "reason": "Avoid repeated scanning of kit-generated deployment reports.",
      "required": false,
      "failurePolicy": "manual"
    },
    {
      "id": "vscode-portable",
      "type": "process",
      "value": "${ToolRoot}\\vscode-portable\\Code.exe",
      "scope": "vscode-portable",
      "reason": "Allow the explicitly managed portable VSCode executable used by this kit.",
      "required": false,
      "failurePolicy": "manual",
      "owner": "maintainer"
    },
    {
      "id": "cmder-portable",
      "type": "process",
      "value": "${ToolRoot}\\cmder\\Cmder.exe",
      "scope": "cmder-portable",
      "reason": "Allow the explicitly managed portable Cmder executable used by this kit.",
      "required": false,
      "failurePolicy": "manual",
      "owner": "maintainer"
    }
  ],
  "stateChecks": [
    {
      "name": "DefenderRealtimeProtection",
      "settingName": "DisableRealtimeMonitoring",
      "expectedValue": false,
      "required": true,
      "failurePolicy": "fail"
    }
  ]
}
