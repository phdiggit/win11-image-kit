{
  "$schema": "../schemas/future-true-ux-restore-authorization.schema.json",
  "schemaVersion": 1,
  "mode": "authorization-intake",
  "defaultDecision": "blocked",
  "allowRegistryMutation": false,
  "allowProfileMutation": false,
  "allowDefaultUserHiveMutation": false,
  "allowDefaultAppMutation": false,
  "allowStartMenuMutation": false,
  "allowTaskbarMutation": false,
  "allowDismMutation": false,
  "allowAppxMutation": false,
  "allowNetworkDownload": false,
  "requiredAuthorizationFields": [
    "scope",
    "targetIdentity",
    "mutationType",
    "expectedBeforeState",
    "allowedCommand",
    "rollbackPlan",
    "beforeEvidence",
    "afterEvidence",
    "independentVerification",
    "failurePropagation",
    "reviewCheckpoint"
  ],
  "currentUserDryRun": {
    "enabled": true,
    "scope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowCurrentUserMutation": false,
    "allowDefaultUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "redactedUserIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "defaultUserDryRun": {
    "enabled": true,
    "scope": "default-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowDefaultUserMutation": false,
    "allowCurrentUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "templateSource",
      "defaultUserTargetIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "offlineImageDryRun": {
    "enabled": true,
    "scope": "offline-image",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowOfflineImageMutation": false,
    "allowCurrentMachineFallback": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "requiredEvidence": [
      "imageIdentity",
      "imageIndex",
      "mountPathPlaceholder",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackOrUnmountPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "machineDryRun": {
    "enabled": true,
    "scope": "machine",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowMachineMutation": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "machineIdentity",
      "machineSettingTarget",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "adminOrVmSmokeBoundary",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "authorizationReview": {
    "enabled": true,
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "allowedReviewDecisions": [
      "blocked",
      "needs-more-evidence",
      "authorization-review-ready",
      "rejected"
    ],
    "forbiddenReviewDecisions": [
      "execute-ready"
    ],
    "requiredPacketFields": [
      "scope",
      "targetIdentity",
      "requestedMutationType",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "beforeEvidence",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "scopeGuardAssertion",
      "privacyRedactionStatement",
      "failurePropagation",
      "reviewerChecklist"
    ]
  },
  "mockReviewDrill": {
    "enabled": true,
    "mode": "mock-review-drill",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedMockDecisions": [
      "authorization-review-ready",
      "needs-more-evidence",
      "rejected",
      "blocked"
    ],
    "forbiddenMockDecisions": [
      "execute-ready",
      "executed",
      "completed"
    ]
  },
  "endToEndNoExecutionReadinessAudit": {
    "enabled": true,
    "mode": "end-to-end-no-execution-readiness-audit",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "requiredLayers": [
      "authorization-intake",
      "current-user-dry-run",
      "default-user-dry-run",
      "offline-image-dry-run",
      "machine-dry-run",
      "authorization-review",
      "mock-review-drill"
    ],
    "forbiddenStates": [
      "execute-ready",
      "executed",
      "completed",
      "issue-18-complete",
      "closure-ready"
    ]
  },
  "finalStopLineHandoff": {
    "enabled": true,
    "mode": "final-stop-line-handoff",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedStopLineDecisions": [
      "pause-at-stop-line",
      "request-rework",
      "start-true-restore-planning",
      "close-issue-manually"
    ],
    "forbiddenStopLineStates": [
      "execute-ready",
      "executed",
      "completed",
      "issue-18-complete",
      "closure-ready"
    ],
    "requiredCompletedPreparationLayers": [
      "authorization-intake",
      "current-user-dry-run",
      "default-user-dry-run",
      "offline-image-dry-run",
      "machine-dry-run",
      "authorization-review",
      "mock-review-drill",
      "end-to-end-no-execution-readiness-audit"
    ],
    "requiredStopLineDocs": [
      "docs/archive/future-true-ux-restore/00-governance/106-future-true-ux-restore-final-stop-line-handoff.md",
      "docs/archive/future-true-ux-restore/00-governance/107-future-true-ux-restore-stop-line-decision-matrix.md"
    ],
    "requiresNewRunnerGateForTrueRestorePlanning": true
  }
}
