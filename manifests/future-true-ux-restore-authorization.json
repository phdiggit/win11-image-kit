{
  "$schema": "../schemas/future-true-ux-restore-authorization.schema.json",
  "schemaVersion": 1,
  "mode": "authorization-intake",
  "defaultDecision": "blocked",
  "allowRegistryMutation": false,
  "allowProfileMutation": false,
  "allowDefaultUserHiveMutation": false,
  "allowDefaultAppMutation": false,
  "allowStartMenuMutation": false,
  "allowTaskbarMutation": false,
  "allowDismMutation": false,
  "allowAppxMutation": false,
  "allowNetworkDownload": false,
  "requiredAuthorizationFields": [
    "scope",
    "targetIdentity",
    "mutationType",
    "expectedBeforeState",
    "allowedCommand",
    "rollbackPlan",
    "beforeEvidence",
    "afterEvidence",
    "independentVerification",
    "failurePropagation",
    "reviewCheckpoint"
  ],
  "currentUserDryRun": {
    "enabled": true,
    "scope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowCurrentUserMutation": false,
    "allowDefaultUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "redactedUserIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "defaultUserDryRun": {
    "enabled": true,
    "scope": "default-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowDefaultUserMutation": false,
    "allowCurrentUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "templateSource",
      "defaultUserTargetIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "offlineImageDryRun": {
    "enabled": true,
    "scope": "offline-image",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowOfflineImageMutation": false,
    "allowCurrentMachineFallback": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "requiredEvidence": [
      "imageIdentity",
      "imageIndex",
      "mountPathPlaceholder",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackOrUnmountPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "machineDryRun": {
    "enabled": true,
    "scope": "machine",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowMachineMutation": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "machineIdentity",
      "machineSettingTarget",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "adminOrVmSmokeBoundary",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "authorizationReview": {
    "enabled": true,
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "allowedReviewDecisions": [
      "blocked",
      "needs-more-evidence",
      "authorization-review-ready",
      "rejected"
    ],
    "forbiddenReviewDecisions": [
      "execute-ready"
    ],
    "requiredPacketFields": [
      "scope",
      "targetIdentity",
      "requestedMutationType",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "beforeEvidence",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "scopeGuardAssertion",
      "privacyRedactionStatement",
      "failurePropagation",
      "reviewerChecklist"
    ]
  },
  "mockReviewDrill": {
    "enabled": true,
    "mode": "mock-review-drill",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedMockDecisions": [
      "authorization-review-ready",
      "needs-more-evidence",
      "rejected",
      "blocked"
    ],
    "forbiddenMockDecisions": [
      "execute-ready",
      "executed",
      "completed"
    ]
  },
  "negativeReviewDrill": {
    "enabled": true,
    "mode": "negative-review-drill",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedNegativeDecisions": [
      "blocked",
      "needs-rework",
      "rejected"
    ],
    "forbiddenNegativeDecisions": [
      "authorization-review-ready",
      "execute-ready",
      "executed",
      "completed"
    ],
    "requiredReasonCodes": [
      "missing-maintainer-approval",
      "scope-ambiguous-or-expanded",
      "exit-code-not-ux-evidence",
      "report-only-not-real-evidence",
      "mock-only-not-real-evidence",
      "stale-or-inconsistent-packet",
      "missing-rollback-plan",
      "high-risk-mutation-intent"
    ]
  },
  "approvalChecklistErgonomics": {
    "enabled": true,
    "mode": "approval-checklist-ergonomics",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedChecklistDecisions": [
      "approval-checklist-ready",
      "needs-rework",
      "blocked"
    ],
    "forbiddenChecklistDecisions": [
      "authorization-review-ready",
      "execute-ready",
      "executed",
      "completed"
    ],
    "requiredChecklistSections": [
      "scope",
      "target-identity-redaction",
      "evidence-boundary",
      "rollback-or-restore-plan",
      "privacy-redaction",
      "reviewer-decision",
      "execution-boundary"
    ]
  },
  "integratedPacketPreview": {
    "enabled": true,
    "mode": "integrated-packet-preview",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedPreviewDecisions": [
      "packet-preview-ready",
      "needs-rework",
      "blocked"
    ],
    "forbiddenPreviewDecisions": [
      "authorization-review-ready",
      "execute-ready",
      "executed",
      "completed"
    ],
    "requiredPreviewSections": [
      "scope",
      "target-identity-redaction",
      "evidence-boundary",
      "approval-checklist-summary",
      "negative-blocker-summary",
      "rollback-or-restore-plan",
      "execution-boundary",
      "runner-gate-reminder"
    ]
  },
  "humanAuthorizationHandoff": {
    "enabled": true,
    "mode": "human-authorization-handoff",
    "defaultScope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedHandoffDecisions": [
      "handoff-ready-for-human-review",
      "needs-rework",
      "blocked"
    ],
    "forbiddenHandoffDecisions": [
      "authorization-review-ready",
      "execute-ready",
      "executed",
      "completed",
      "issue-18-complete",
      "closure-ready"
    ],
    "requiredHandoffSections": [
      "scope",
      "artifact-index",
      "identity-redaction",
      "evidence-boundary",
      "approval-checklist-summary",
      "negative-blocker-summary",
      "integrated-preview-summary",
      "rollback-or-restore-plan",
      "runner-gate-reminder",
      "manual-decision-placeholder",
      "non-execution-statement"
    ]
  },
  "endToEndNoExecutionReadinessAudit": {
    "enabled": true,
    "mode": "end-to-end-no-execution-readiness-audit",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "requiredLayers": [
      "authorization-intake",
      "current-user-dry-run",
      "default-user-dry-run",
      "offline-image-dry-run",
      "machine-dry-run",
      "authorization-review",
      "mock-review-drill",
      "negative-review-drill",
      "approval-checklist-ergonomics",
      "integrated-packet-preview",
      "human-authorization-handoff"
    ],
    "forbiddenStates": [
      "execute-ready",
      "executed",
      "completed",
      "issue-18-complete",
      "closure-ready"
    ]
  },
  "finalStopLineHandoff": {
    "enabled": true,
    "mode": "final-stop-line-handoff",
    "authorizationApproved": false,
    "executionApproved": false,
    "executeReady": false,
    "trueExecution": false,
    "mutationCount": 0,
    "allowedStopLineDecisions": [
      "pause-at-stop-line",
      "request-rework",
      "start-true-restore-planning",
      "close-issue-manually"
    ],
    "forbiddenStopLineStates": [
      "execute-ready",
      "executed",
      "completed",
      "issue-18-complete",
      "closure-ready"
    ],
    "requiredCompletedPreparationLayers": [
      "authorization-intake",
      "current-user-dry-run",
      "default-user-dry-run",
      "offline-image-dry-run",
      "machine-dry-run",
      "authorization-review",
      "mock-review-drill",
      "negative-review-drill",
      "approval-checklist-ergonomics",
      "integrated-packet-preview",
      "human-authorization-handoff",
      "end-to-end-no-execution-readiness-audit"
    ],
    "requiredStopLineDocs": [
      "docs/archive/future-true-ux-restore/00-governance/106-future-true-ux-restore-final-stop-line-handoff.md",
      "docs/archive/future-true-ux-restore/00-governance/107-future-true-ux-restore-stop-line-decision-matrix.md"
    ],
    "requiresNewRunnerGateForTrueRestorePlanning": true
  }
