{
  "$schema": "../schemas/future-true-ux-restore-authorization.schema.json",
  "schemaVersion": 1,
  "mode": "authorization-intake",
  "defaultDecision": "blocked",
  "allowRegistryMutation": false,
  "allowProfileMutation": false,
  "allowDefaultUserHiveMutation": false,
  "allowDefaultAppMutation": false,
  "allowStartMenuMutation": false,
  "allowTaskbarMutation": false,
  "allowDismMutation": false,
  "allowAppxMutation": false,
  "allowNetworkDownload": false,
  "requiredAuthorizationFields": [
    "scope",
    "targetIdentity",
    "mutationType",
    "expectedBeforeState",
    "allowedCommand",
    "rollbackPlan",
    "beforeEvidence",
    "afterEvidence",
    "independentVerification",
    "failurePropagation",
    "reviewCheckpoint"
  ],
  "currentUserDryRun": {
    "enabled": true,
    "scope": "current-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowCurrentUserMutation": false,
    "allowDefaultUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "redactedUserIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "defaultUserDryRun": {
    "enabled": true,
    "scope": "default-user",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowDefaultUserMutation": false,
    "allowCurrentUserFallback": false,
    "allowMachineFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "templateSource",
      "defaultUserTargetIdentity",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "offlineImageDryRun": {
    "enabled": true,
    "scope": "offline-image",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowOfflineImageMutation": false,
    "allowCurrentMachineFallback": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "requiredEvidence": [
      "imageIdentity",
      "imageIndex",
      "mountPathPlaceholder",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackOrUnmountPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  },
  "machineDryRun": {
    "enabled": true,
    "scope": "machine",
    "authorizationApproved": false,
    "executionApproved": false,
    "defaultDecision": "blocked",
    "allowMachineMutation": false,
    "allowCurrentUserFallback": false,
    "allowDefaultUserFallback": false,
    "allowOfflineImageFallback": false,
    "requiredEvidence": [
      "machineIdentity",
      "machineSettingTarget",
      "beforeEvidence",
      "dryRunCommandEnvelope",
      "rollbackPlan",
      "afterEvidencePlaceholder",
      "independentVerificationPlaceholder",
      "adminOrVmSmokeBoundary",
      "failurePropagation",
      "reviewCheckpoint"
    ]
  }
}
