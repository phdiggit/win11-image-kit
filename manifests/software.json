{
  "$schema": "../schemas/software.schema.json",
  "packages": [
    {
      "name": "maven",
      "version": "3.9.16",
      "enabled": true,
      "category": "dev-runtime",
      "stage": "golden-image",
      "type": "archive",
      "archiveFormat": "tar.gz",
      "source": "${PackageRoot}\\maven\\apache-maven-3.9.16-bin.tar.gz",
      "sha256": null,
      "destination": "${ToolRoot}\\apache-maven-3.9.16",
      "env": {
        "MAVEN_HOME": "${ToolRoot}\\apache-maven-3.9.16"
      },
      "path": [
        "${ToolRoot}\\apache-maven-3.9.16\\bin"
      ],
      "test": "mvn -v"
    },
    {
      "name": "vscode-portable",
      "version": "1.124.0",
      "enabled": true,
      "category": "editor",
      "stage": "golden-image",
      "type": "archive",
      "archiveFormat": "zip",
      "source": "${PackageRoot}\\vscode\\VSCode-win32-x64-1.124.0.zip",
      "sha256": null,
      "destination": "${ToolRoot}\\vscode-portable",
      "postInstall": [
        {
          "action": "ensure-directory",
          "path": "${ToolRoot}\\vscode-portable\\data"
        }
      ],
      "test": "${ToolRoot}\\vscode-portable\\Code.exe --version"
    },
    {
      "name": "codex",
      "version": "latest",
      "enabled": true,
      "category": "ai-tools",
      "stage": "post-deploy",
      "type": "installer",
      "source": "${PackageRoot}\\ai-tools\\Codex Installer.exe",
      "sha256": null,
      "destination": "C:\\Program Files\\Codex",
      "installArgs": [],
      "silentInstall": false,
      "uninstall": null,
      "test": "where codex"
    }
  ]
}
