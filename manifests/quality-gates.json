{
  "$schema": "../schemas/quality-gates.schema.json",
  "manifestVersion": 1,
  "gates": [
    {
      "id": "json-parse",
      "displayName": "JSON parse validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "workflow-step",
      "notes": "Parses manifests and schemas without network access."
    },
    {
      "id": "powershell-parse",
      "displayName": "PowerShell parse validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "workflow-step",
      "notes": "Parses scripts without executing business handlers."
    },
    {
      "id": "project-config",
      "displayName": "Project config validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-ProjectConfig.ps1",
      "evidence": "report",
      "notes": "Validates manifests, schemas, paths, and static references."
    },
    {
      "id": "psscriptanalyzer",
      "displayName": "PSScriptAnalyzer baseline",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": false,
      "entrypoint": "PSScriptAnalyzerSettings.psd1",
      "evidence": "workflow-step",
      "notes": "Analyzer availability or diagnostics are warning/manual under current policy."
    },
    {
      "id": "pester-fast-inventory",
      "displayName": "PR fast Pester inventory",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "fixture",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "pester",
      "notes": "Runs the curated fast Pester list on pull requests."
    },
    {
      "id": "pester-full-inventory",
      "displayName": "Full Pester inventory",
      "layer": "full-validate",
      "trigger": "main-push",
      "mode": "fixture",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "pester",
      "notes": "Runs the broader tests/pester inventory on main push or workflow_dispatch."
    },
    {
      "id": "build-lock",
      "displayName": "Build Lock validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-BuildLock.ps1",
      "evidence": "report",
      "notes": "Validates trusted input hashes and watched-file review signals."
    },
    {
      "id": "ci-policy",
      "displayName": "CI workflow policy",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "pester",
      "notes": "Guards Validate versus Full Validate split and no-mutation workflow policy."
    },
    {
      "id": "safety-boundary",
      "displayName": "Safety boundary",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/40-issue14-quality-gates.md",
      "evidence": "document",
      "notes": "Documents that real build, mutation, network, signing, and registry/profile/hive writes are out of scope."
    },
    {
      "id": "issue14-acceptance",
      "displayName": "Issue 14 acceptance scaffold",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/41-issue14-quality-gates-acceptance.md",
      "evidence": "document",
      "notes": "Provides the in-acceptance scaffold without close-prep or main-evidence claims."
    },
    {
      "id": "effective-configuration",
      "displayName": "Effective configuration validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-EffectiveConfiguration.ps1",
      "evidence": "report",
      "notes": "Validates Issue 15 layered configuration with all tracked stacks, CLI override fixture, local static inputs, and failedCount=0."
    },
    {
      "id": "evidence-chain",
      "displayName": "Evidence chain report validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-EvidenceChain.ps1",
      "evidence": "report",
      "notes": "Validates Issue 16 evidence chain runId inheritance, artifact index, report input index, producer normalization counters, redaction policy including PowerShell 7 scalar leaf traversal, ready-state scaffold, fixture reports, and safety flags without true execution."
    },
    {
      "id": "controlled-execution",
      "displayName": "Controlled execution dry-run validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-ControlledExecution.ps1",
      "evidence": "report",
      "notes": "Validates Issue 17 controlled execution manifest, dry-run report, safety policy, and blocked mutation semantics without true execution."
    },
    {
      "id": "issue17-intake",
      "displayName": "Issue 17 intake",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/52-issue17-controlled-execution-intake.md",
      "evidence": "document",
      "notes": "Records real Issue 17 and Roadmap intake without close-prep or auto-close."
    },
    {
      "id": "issue17-acceptance",
      "displayName": "Issue 17 acceptance scaffold",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/53-issue17-controlled-execution-acceptance.md",
      "evidence": "document",
      "notes": "Records in-acceptance dry-run coverage without final closure."
    },
    {
      "id": "issue16-acceptance",
      "displayName": "Issue 16 acceptance",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/49-issue16-evidence-chain-acceptance.md",
      "evidence": "document",
      "notes": "Records accepted-ready-for-manual-closure without automatic closure."
    },
    {
      "id": "issue16-close-prep",
      "displayName": "Issue 16 ready close-prep",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "manual",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/50-issue16-close-preparation.md",
      "evidence": "document",
      "notes": "Provides manual closure readiness only; PR Fast CI is not main evidence."
    },
    {
      "id": "issue16-main-evidence-scaffold",
      "displayName": "Issue 16 main evidence",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/51-issue16-main-validation-evidence.md",
      "evidence": "document",
      "notes": "Records real post-PR #84 main push Full Validate evidence for manual closure review."
    },
    {
      "id": "effective-configuration-consumer-integration",
      "displayName": "Effective configuration consumer integration",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "fixture",
      "required": true,
      "blocking": true,
      "entrypoint": "tests/pester/EffectiveConfigurationConsumerIntegration.Tests.ps1",
      "evidence": "pester",
      "notes": "Validates Show-CustomizationScope default compatibility and opt-in effective configuration source-layer display."
    },
    {
      "id": "issue15-acceptance",
      "displayName": "Issue 15 accepted ready for manual closure",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/45-issue15-layered-configuration-acceptance.md",
      "evidence": "document",
      "notes": "Documents functional acceptance after post-merge main/workflow validation evidence is recorded."
    },
    {
      "id": "issue15-close-prep",
      "displayName": "Issue 15 ready close-prep",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "manual",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/46-issue15-close-preparation.md",
      "evidence": "document",
      "notes": "Provides manual closure readiness only; PR Fast CI is not main evidence."
    },
    {
      "id": "issue15-main-evidence",
      "displayName": "Issue 15 main evidence",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "report-only",
      "required": true,
      "blocking": true,
      "entrypoint": "docs/47-issue15-main-validation-evidence.md",
      "evidence": "document",
      "notes": "Records real main push or workflow_dispatch Full Validate evidence for manual closure review."
    }
  ]
}
