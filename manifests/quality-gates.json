      "displayName": "PR fast Pester inventory",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "fixture",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "pester",
      "notes": "Runs the curated fast Pester list on pull requests."
    },
    {
      "id": "pester-full-inventory",
      "displayName": "Full Pester inventory",
      "layer": "full-validate",
      "trigger": "main-push",
      "mode": "fixture",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "pester",
      "notes": "Runs the broader tests/pester inventory on main push or workflow_dispatch."
