{
  "$schema": "../schemas/quality-gates.schema.json",
  "manifestVersion": 1,
  "gates": [
    {
      "id": "json-parse",
      "displayName": "JSON parse validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "workflow-step",
      "notes": "Parses manifests and schemas without network access."
    },
    {
      "id": "powershell-parse",
      "displayName": "PowerShell parse validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": ".github/workflows/ci.yml",
      "evidence": "workflow-step",
      "notes": "Parses scripts without executing business handlers."
    },
    {
      "id": "project-config",
      "displayName": "Project config validation",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": true,
      "entrypoint": "scripts/validate/Test-ProjectConfig.ps1",
      "evidence": "report",
      "notes": "Validates manifests, schemas, paths, and static references."
    },
    {
      "id": "psscriptanalyzer",
      "displayName": "PSScriptAnalyzer baseline",
      "layer": "pr-fast",
      "trigger": "pull_request",
      "mode": "static",
      "required": true,
      "blocking": false,
      "entrypoint": "PSScriptAnalyzerSettings.psd1",
      "evidence": "workflow-step",
      "notes": "Analyzer availability or diagnostics are warning/manual under current policy."
    },
    {
