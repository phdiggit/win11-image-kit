{
  "$schema": "../schemas/customization-scope.schema.json",
  "profile": "default",
  "goal": "还原到新机后，只保留账号登录、授权激活和硬件相关确认等少量手工操作。",
  "pathsManifest": "manifests/paths.json",
  "system": {
    "contextMenu": {
      "enabled": true,
      "items": [
        "vscode-open-here"
      ]
    },
    "startMenu": {
      "enabled": true,
      "config": "${ConfigRoot}\\start-menu",
      "stateChecks": [
        {
          "name": "StartMenuDefaultLayoutRestored",
          "domain": "startMenu",
          "settingName": "开始菜单默认布局",
          "expectedValue": "restored",
          "required": true,
          "failurePolicy": "fail"
        }
      ]
    },
    "windowsTerminal": {
      "enabled": true,
      "source": "${ConfigRoot}\\windows-terminal",
      "destination": "%LOCALAPPDATA%\\Packages\\Microsoft.WindowsTerminal_8wekyb3d8bbwe\\LocalState",
      "stateChecks": [
        {
          "name": "WindowsTerminalConfigRestored",
          "domain": "terminal",
          "settingName": "Windows Terminal 配置模板",
          "expectedValue": "restored",
          "required": true,
          "failurePolicy": "fail"
        }
      ]
    },
    "explorerOptions": {
      "enabled": true,
      "showFileExtensions": true,
      "showHiddenFiles": true,
      "stateChecks": [
        {
          "name": "ExplorerOptionsRestored",
          "domain": "explorer",
          "settingName": "资源管理器选项",
          "expectedValue": "restored",
          "required": true,
          "failurePolicy": "fail"
        }
      ]
    },
    "defaultApps": {
      "enabled": true,
      "associationFile": "${ConfigRoot}\\default-apps\\DefaultAppAssoc.xml",
      "stateChecks": [
        {
          "name": "DefaultAppsImported",
          "domain": "defaultApps",
          "settingName": "默认应用关联",
          "expectedValue": "restored",
          "required": true,
          "failurePolicy": "fail"
        }
      ]
    },
    "vscodePortable": {
      "enabled": true,
      "source": "${ConfigRoot}\\vscode-portable\\data",
      "destination": "${ToolRoot}\\vscode-portable\\data",
      "stateChecks": [
        {
          "name": "VSCodePortableDataRestored",
          "domain": "userExperience",
          "settingName": "VSCode 便携版 data 配置目录",
          "expectedValue": "restored",
          "required": false,
          "failurePolicy": "manual"
        }
      ]
    },
    "windowsDefender": {
      "mode": "enabled-with-exclusions",
      "exclusionsManifest": "manifests/defender-exclusions.json"
    },
    "huorong": {
      "install": false,
      "packageName": "huorong"
    }
  },
  "appx": {
    "policy": "remove-listed-microsoft-apps",
    "removeManifest": "manifests/appx-cleanup.json",
    "keepPatterns": [
      "Baidu",
      "Netdisk"
    ]
  },
  "applications": {
    "softwareManifest": "manifests/software.json",
    "servicesManifest": "manifests/services.json",
    "junctionsManifest": "manifests/junctions.json"
  },
  "reporting": {
    "build": {
      "enabled": false,
      "logDirectory": "${DeployRoot}\\logs\\build",
      "reportDirectory": "${DeployRoot}\\reports\\build"
    },
    "postDeploy": {
      "enabled": false,
      "logDirectory": "${DeployRoot}\\logs\\postdeploy",
      "reportDirectory": "${DeployRoot}\\reports\\postdeploy"
    },
    "validation": {
      "enabled": false,
      "logDirectory": "${DeployRoot}\\logs\\validation",
      "reportDirectory": "${DeployRoot}\\reports\\validation"
    }
  },
  "userInteraction": {
    "editableBeforeRun": true,
    "allowedChanges": [
      "修改 paths.json 中的 NAS、本机工具目录和数据目录",
      "在 software.json 中增删安装包或便携包",
      "在 customization-scope.json 中启用或停用系统定制项",
      "按需开启 reporting 配置，把日志和报告归档到 DeployRoot 下",
      "在 ConfigRoot 下维护 Windows Terminal 和 VSCode 便携版配置模板",
      "在 defender-exclusions.json 中增删可信目录或进程排除项",
      "在 junctions.json 中增删需要迁移到数据盘的目录"
    ]
  }
}
