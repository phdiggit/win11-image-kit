{
  "$schema": "../schemas/junctions.schema.json",
  "junctions": [
    {
      "description": "Maven 本地仓库",
      "source": "%USERPROFILE%\\.m2\\repository",
      "target": "${DataRoot}\\maven\\repository"
    },
    {
      "description": "JetBrains 缓存索引",
      "source": "%LOCALAPPDATA%\\JetBrains",
      "target": "${DataRoot}\\JetBrains\\cache"
    },
    {
      "description": "MySQL 数据目录",
      "source": "${ToolRoot}\\mysql\\data",
      "target": "${DataRoot}\\mysql\\data"
    },
    {
      "description": "MongoDB 数据目录",
      "source": "${ToolRoot}\\mongodb\\data",
      "target": "${DataRoot}\\mongodb\\data"
    },
    {
      "description": "npm 全局模块",
      "source": "${ToolRoot}\\npm-global",
      "target": "${DataRoot}\\npm\\global"
    },
    {
      "description": "Conda 虚拟环境",
      "source": "${ToolRoot}\\miniconda3\\envs",
      "target": "${DataRoot}\\conda\\envs"
    }
  ]
}
